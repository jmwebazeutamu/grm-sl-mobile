{
  "expo": {
    "name": "GRM Sierra Leone",
    "slug": "grm-sl-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "grmsl",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sl.gov.grm.mobile"
    },
    "android": {
      "package": "sl.gov.grm.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundImage": "./assets/images/adaptive-bg.png",
        "monochromeImage": "./assets/images/adaptive-mono.png",
        "backgroundColor": "#1eb53a"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos to grievances.",
          "cameraPermission": "Take photos to attach to grievances."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0072c6"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://grm-sl.quasar.ug/api/v1/mobile",
      "router": {},
      "eas": {
        "projectId": "3a293e05-65aa-4c16-94af-f1cada67e527"
      }
    },
    "owner": "mwebazej"
  }
}
